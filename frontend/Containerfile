# syntax=docker/dockerfile:1
# Career Copilot — Next.js frontend
# Build: podman build -f Containerfile -t career-copilot-frontend .
# Run:   podman run -p 3000:3000 --env NEXT_PUBLIC_API_BASE=http://backend:8000 career-copilot-frontend

# ──────────────────────────────────────────────────────────────
# Stage 1: deps — install production + dev dependencies
# ──────────────────────────────────────────────────────────────
FROM node:20-slim AS deps
WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --prefer-offline

# ──────────────────────────────────────────────────────────────
# Stage 2: build
# ──────────────────────────────────────────────────────────────
FROM node:20-slim AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Pass build-time API base; can be overridden at runtime via env
ARG NEXT_PUBLIC_API_BASE=http://localhost:8000
ENV NEXT_PUBLIC_API_BASE=$NEXT_PUBLIC_API_BASE
# Enable standalone output for Docker self-hosting
ENV NEXT_OUTPUT=standalone

RUN npm run build

# ──────────────────────────────────────────────────────────────
# Stage 3: runner — minimal production image
# ──────────────────────────────────────────────────────────────
FROM node:20-slim AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

# next/standalone output bundles everything needed
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

CMD ["node", "server.js"]
