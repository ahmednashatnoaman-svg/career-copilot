# ══════════════════════════════════════════════════════════
#  AI Career Copilot — Environment Variables
#  Copy to .env and fill in your values.
#  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════

# --- LLM (primary: groq; fallback: azure or google) ---
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_MODEL_FAST=llama-3.1-8b-instant
GROQ_API_KEY=
GOOGLE_API_KEY=

# --- Azure OpenAI (AI Foundry endpoint — set LLM_PROVIDER=azure to use as primary) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-small

# --- Supabase (Auth + Postgres DB) ---
# Get from: supabase.com → project → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Get from: supabase.com → project → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres.your-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# --- Vector database ---
# Local (dev):
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
# Qdrant Cloud (prod): https://cloud.qdrant.io
# QDRANT_URL=https://your-cluster.qdrant.io
# QDRANT_API_KEY=your-qdrant-api-key

# --- Web search ---
TAVILY_API_KEY=

# --- LangSmith tracing ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=career-copilot

# --- Job sources ---
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
GITHUB_TOKEN=

# --- CORS (set to your Vercel URL in production) ---
FRONTEND_URL=http://localhost:3000

# --- Render (auto-set by platform, no need to set manually) ---
# RENDER_EXTERNAL_URL=https://career-copilot-api.onrender.com
