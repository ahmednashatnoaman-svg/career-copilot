# syntax=docker/dockerfile:1
# Career Copilot — Next.js frontend
# Build: podman build -f Containerfile -t career-copilot-frontend .
# Run:   podman run -p 3000:3000 --env NEXT_PUBLIC_API_BASE=http://backend:8000 career-copilot-frontend

# ──────────────────────────────────────────────────────────────
# Stage 1: deps — install production + dev dependencies
# ──────────────────────────────────────────────────────────────
FROM node:20-slim AS deps
WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --prefer-offline

# ──────────────────────────────────────────────────────────────
# Stage 2: build
# ──────────────────────────────────────────────────────────────
FROM node:20-slim AS builder
WORKDIR /app

COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Pass build-time vars — NEXT_PUBLIC_* are baked into the JS bundle.
# Supabase vars default to placeholders so the image builds without secrets;
# pass real values via --build-arg in production CI.
ARG NEXT_PUBLIC_API_BASE=http://localhost:8000
ARG NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
ARG NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key-for-docker-build
ENV NEXT_PUBLIC_API_BASE=$NEXT_PUBLIC_API_BASE
ENV NEXT_PUBLIC_SUPABASE_URL=$NEXT_PUBLIC_SUPABASE_URL
ENV NEXT_PUBLIC_SUPABASE_ANON_KEY=$NEXT_PUBLIC_SUPABASE_ANON_KEY
# Enable standalone output for Docker self-hosting
ENV NEXT_OUTPUT=standalone

RUN npm run build

# ──────────────────────────────────────────────────────────────
# Stage 3: runner — minimal production image
# ──────────────────────────────────────────────────────────────
FROM node:20-slim AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

# next/standalone output bundles everything needed
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

CMD ["node", "server.js"]
